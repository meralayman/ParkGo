# Copy to `.env` in this folder and restart Expo with `-c`.
# Physical device / different OS: use your PC LAN IP + backend port (not 127.0.0.1 on phone).
#
# Prefer this name (same as sibling mobile-app):
EXPO_PUBLIC_API_BASE_URL=http://172.20.10.4:5000

# Alias also supported:
# EXPO_PUBLIC_API_BASE=http://172.20.10.4:5000

# Optional: ParkGo web (CRA) base for opening lot designer in browser
# EXPO_PUBLIC_WEB_BASE=http://172.20.10.4:3000
