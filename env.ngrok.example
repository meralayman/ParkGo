# If opening https://YOUR-SUBDOMAIN.ngrok-free.dev shows JSON {"name":"ParkGo API"...}, that tunnel is the BACKEND (port 5000).
# Put that URL in project root .env:
REACT_APP_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev
#
# Open the React UI at http://localhost:3000 (or run a second ngrok: ngrok http 3000 for another https URL).
# backend/.env FRONTEND_URL must be where the SPA runs (usually http://localhost:3000), not the API tunnel.
